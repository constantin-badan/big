{
  "name": "trading-bot",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "format": "oxfmt --write packages/",
    "format:check": "oxfmt --check packages/",
    "lint:boundaries": "eslint 'packages/*/src/**/*.ts'",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "test": "nx run-many -t test"
  },
  "devDependencies": {
    "@nx/eslint-plugin": "^22.6.1",
    "@nx/js": "^22.6.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.11",
    "@typescript-eslint/parser": "^8.57.2",
    "@typescript/native-preview": "^7.0.0-dev.20260326.1",
    "eslint": "^10.1.0",
    "nx": "^22.6.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.17.4",
    "typescript": "^6.0.2"
  }
}
